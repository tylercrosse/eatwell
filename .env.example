# --- OpenRouter (required for /api/analyze) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3-flash-preview
# Optional attribution headers shown on openrouter.ai
APP_TITLE=Calorie Tracker
APP_REFERER=http://localhost:5173

# --- USDA FoodData Central (grounds the text-description estimate) ---
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
# Leave blank to fall back to an ungrounded pure-LLM estimate.
USDA_API_KEY=

# --- Storage paths (defaults are fine for local dev) ---
DB_PATH=data/app.db
PHOTOS_DIR=data/photos

# --- Serving ---
# When true, FastAPI also serves the built PWA from web/dist (single-service deploy).
# Set false to run frontend separately (Vite dev server / static host).
SERVE_STATIC=false
STATIC_DIR=web/dist
# Comma-separated origins allowed by CORS (frontend dev servers / tunnels).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth (Google sign-in) ---
# OAuth 2.0 Web client id from Google Cloud Console (APIs & Services > Credentials).
# Add your app origins to the client's "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=
# Comma-separated allowlist — only these emails may sign in. Leave blank to allow any
# verified Google account (do NOT leave blank on a public deployment).
ALLOWED_EMAILS=you@example.com,partner@example.com
# Long random secret signing your session cookies. Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-value
# Optional: this email's first login adopts pre-auth (pre-login) data. Blank = off.
OWNER_EMAIL=you@example.com
# Set true when serving over HTTPS so the session cookie is HTTPS-only.
COOKIE_SECURE=false
