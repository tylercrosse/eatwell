# --- OpenRouter (required for /api/analyze) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3-flash-preview
# Optional attribution headers shown on openrouter.ai
APP_TITLE=Calorie Tracker
APP_REFERER=http://localhost:5173

# --- Storage paths (defaults are fine for local dev) ---
DB_PATH=data/app.db
PHOTOS_DIR=data/photos

# --- Serving ---
# When true, FastAPI also serves the built PWA from web/dist (single-service deploy).
# Set false to run frontend separately (Vite dev server / static host).
SERVE_STATIC=false
STATIC_DIR=web/dist
# Comma-separated origins allowed by CORS (frontend dev servers / tunnels).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
