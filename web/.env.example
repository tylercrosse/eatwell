# Frontend build-time config (Vite). Copy to web/.env.local and fill in.

# Google OAuth Web client id (same value as the backend's GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=1061368975039-gscug66af6koc7ovvkjdd6l4cam7eusa.apps.googleusercontent.com

# Backend base URL. Defaults to "/api" (same-origin / Vite dev proxy); override only
# when the API is on a different origin.
# VITE_API_BASE_URL=http://localhost:8000/api
